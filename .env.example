# KiriminAja Plugin — Build Environment URLs
# Copy this file to .env and fill in the actual values.
# .env is gitignored and never committed.
#
# Usage:
#   make zip          → production (API_BASE_URL_PRD)
#   make zip stg      → staging    (API_BASE_URL_STG)
#   make zip dev      → development (API_BASE_URL_DEV)

API_BASE_URL_PRD=https://client.kiriminaja.com
API_BASE_URL_STG=https://tdev.kiriminaja.com
API_BASE_URL_DEV=https://